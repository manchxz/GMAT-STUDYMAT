# PostgreSQL — private database (see docker-compose.yml for local)
DATABASE_URL="postgresql://gmat:gmat_local_secret_change_me@localhost:5432/gmat_trainer?schema=public"

# Session signing — min 16 characters; use a long random string in production
SESSION_SECRET="replace-with-long-random-string"

# Email OTP (Resend) — https://resend.com
# RESEND_API_KEY=
# EMAIL_FROM="Logic Field Guide <onboarding@yourdomain.com>"

# Optional SMS OTP (Twilio) — only if users register with a phone number
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+15551234567

# Development: include OTP in API JSON when email/SMS is not configured (never in production)
# OTP_DEBUG=1
